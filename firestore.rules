rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isParticipant(callData) {
      return isAuthenticated() && (request.auth.uid == callData.callerId || request.auth.uid == callData.calleeId);
    }

    match /users/{userId} {
      // Anyone authenticated can read user profiles for the contact book
      allow read: if isAuthenticated();
      
      // Users can only create/update their own profile
      allow create, update: if isOwner(userId) && 
                            request.resource.data.uid == userId &&
                            request.resource.data.keys().hasAll(['uid', 'displayName', 'email', 'isOnline']);
    }

    match /calls/{callId} {
      // Participants can read the call
      allow read: if isParticipant(resource.data);
      
      // Caller can create the call
      allow create: if isAuthenticated() && 
                    request.resource.data.callerId == request.auth.uid &&
                    request.resource.data.keys().hasAll(['callerId', 'calleeId', 'status', 'type', 'createdAt']);
                    
      // Participants can update the call
      allow update: if isParticipant(resource.data) && isParticipant(request.resource.data);
      
      match /callerCandidates/{candidateId} {
        // Only participants can read/write candidates
        allow read, write: if isParticipant(get(/databases/$(database)/documents/calls/$(callId)).data);
      }
      
      match /calleeCandidates/{candidateId} {
        // Only participants can read/write candidates
        allow read, write: if isParticipant(get(/databases/$(database)/documents/calls/$(callId)).data);
      }
    }
  }
}
