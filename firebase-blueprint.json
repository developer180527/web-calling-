{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user of the calling app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "number" },
        "currentCallId": { "type": "string" },
        "fcmToken": { "type": "string" }
      },
      "required": ["uid", "displayName", "email", "isOnline"]
    },
    "Call": {
      "title": "Call",
      "description": "A WebRTC call session between two users.",
      "type": "object",
      "properties": {
        "callerId": { "type": "string" },
        "calleeId": { "type": "string" },
        "status": { "type": "string", "enum": ["calling", "answered", "rejected", "ended"] },
        "type": { "type": "string", "enum": ["audio", "video"] },
        "offer": { "type": "object" },
        "answer": { "type": "object" },
        "createdAt": { "type": "number" }
      },
      "required": ["callerId", "calleeId", "status", "type", "createdAt"]
    },
    "ICECandidate": {
      "title": "ICECandidate",
      "description": "An ICE candidate for WebRTC connection.",
      "type": "object",
      "properties": {
        "candidate": { "type": "string" },
        "sdpMid": { "type": "string" },
        "sdpMLineIndex": { "type": "number" }
      },
      "required": ["candidate", "sdpMLineIndex"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and online status."
    },
    "/calls/{callId}": {
      "schema": { "$ref": "#/entities/Call" },
      "description": "Stores active and past call sessions."
    },
    "/calls/{callId}/callerCandidates/{candidateId}": {
      "schema": { "$ref": "#/entities/ICECandidate" },
      "description": "ICE candidates generated by the caller."
    },
    "/calls/{callId}/calleeCandidates/{candidateId}": {
      "schema": { "$ref": "#/entities/ICECandidate" },
      "description": "ICE candidates generated by the callee."
    }
  }
}
